# Copy this file to `terraform.tfvars.<env>` (e.g. terraform.tfvars.daddybear)
# and fill in real values. Load it explicitly with
#   AWS_PROFILE=<env> terraform apply -var-file=terraform.tfvars.<env>
# so multiple deployments can share one repo without cross-contamination.
# See the "Switching between AWS accounts" section in README for the full
# workflow (backends/, wrapper function, etc.).
domain      = "daddybearplumbing.com"
bucket_name = "daddybearplumbing-site"
project     = "daddybear"

# All resources — S3, Lambda, Cognito, CodeBuild — live in us-east-1
# (N. Virginia), the same region CloudFront requires the ACM cert to live
# in. Keeping the whole stack in one region simplifies IAM, CloudWatch
# metric aggregation, and the mental model. Must match the region declared
# in backends/<env>.hcl (that's where the Terraform state bucket lives).
region      = "us-east-1"

# If set, this deployment stops serving its own content and instead returns
# HTTP 301 (permanent redirect) to https://<value>/<same-path>. Used to keep
# an old domain working as a permanent redirect after moving traffic to a
# new one (e.g. `redirect_target_domain = "daddybearplumbing.com"` in
# terraform.tfvars.kvaking after the rename). Leave empty for envs that
# serve their own content normally.
redirect_target_domain = ""

# Google Workspace domain-verification token, if the domain's business inbox
# is on Google Workspace. Grabbed from the Google Workspace setup wizard
# (looks like `google-site-verification=IPNT85MrlIU...`). Terraform adds it
# to the apex TXT record alongside SPF so both coexist without one clobbering
# the other. Leave empty for envs that don't use Google Workspace.
google_site_verification = ""

# For a fresh deployment, start with both `false` so the site is doubly
# invisible while you upload content:
#   - publish_dns=false      → the domain doesn't resolve to CloudFront
#   - cloudfront_enabled=false → CloudFront returns HTTP 403 to every request
# Flip both to true (a single `terraform apply -var="…=true"`) when ready to
# launch. CloudFront takes ~5 minutes to propagate the enabled flag globally.
publish_dns        = false
cloudfront_enabled = false

# Fresh AWS accounts start with a regional Lambda concurrency quota of 10,
# so no function can reserve any concurrency. Set to false until you request
# a service-quota increase ("Concurrent executions" / L-B99A9384). Once the
# quota is raised, remove this line so the code default of `true` kicks
# back in and gives per-function reservations (contact_form=10,
# rebuild_trigger=2, rebuild_status=5).
reserve_lambda_concurrency = false

# Admin-triggered rebuild (CodeBuild + GitHub via CodeConnections).
# The connection itself is created by Terraform; you only need to authorise
# it once in the AWS Console after `terraform apply`. See README
# "Admin-Triggered Rebuild" section for details.
github_repo_url = "https://github.com/<owner>/<repo>"
github_branch   = "master"
